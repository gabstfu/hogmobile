<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/db_background">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="48dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="100dp">

        <ImageButton
            android:id="@+id/btn_back_analytics"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_back_arrow"
            app:tint="@color/db_text_primary"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/analytics_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Data Analytics"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/db_text_primary"
            app:layout_constraintStart_toEndOf="@id/btn_back_analytics"
            app:layout_constraintTop_toTopOf="@id/btn_back_analytics"
            app:layout_constraintBottom_toBottomOf="@id/btn_back_analytics" />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/profile_icon_analytics"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/profile_gradient_bg"
            android:padding="2dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_person_white"
            app:shapeAppearanceOverlay="@style/CircleImageView"
            app:strokeColor="@color/white"
            app:strokeWidth="2dp"
            android:elevation="4dp"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/btn_back_analytics"
            app:layout_constraintBottom_toBottomOf="@id/btn_back_analytics" />

        <!-- Stats Grid matching Web Layout -->
        <HorizontalScrollView
            android:id="@+id/stats_scroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:scrollbars="none"
            app:layout_constraintTop_toBottomOf="@id/btn_back_analytics">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="4dp">

                <!-- Total Population Box -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="140dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">
                    <LinearLayout
                        android:padding="12dp"
                        android:orientation="vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView android:text="TOTAL POPULATION" android:textSize="8sp" android:textColor="@color/db_text_secondary" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView
                            android:id="@+id/tv_population"
                            android:text="10"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="@color/db_text_primary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                        <TextView
                            android:id="@+id/tv_active_batches_count"
                            android:text="• 2 Active Batches"
                            android:textColor="#4CAF50"
                            android:textSize="10sp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Next Cycle Box (Paused) -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="140dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">
                    <LinearLayout
                        android:padding="12dp"
                        android:orientation="vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView android:text="NEXT CYCLE" android:textSize="8sp" android:textColor="@color/db_text_secondary" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView
                            android:text="Paused"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="@color/db_text_primary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                        <TextView
                            android:text="Batch: BATCH001"
                            android:textColor="#FF9800"
                            android:textSize="10sp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Today's Feed Box -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="140dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">
                    <LinearLayout
                        android:padding="12dp"
                        android:orientation="vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView android:text="TODAY'S FEED" android:textSize="8sp" android:textColor="@color/db_text_secondary" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView
                            android:id="@+id/tv_total_feed"
                            android:text="0.0 KG"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="@color/db_text_primary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                        <ProgressBar
                            android:id="@+id/feed_progress_bar"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="4dp"
                            android:progress="0"
                            android:progressTint="#2196F3"
                            android:layout_marginTop="8dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Avg Weight Today Box -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="140dp"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#FFE4E4">
                    <LinearLayout
                        android:padding="12dp"
                        android:orientation="vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView android:text="AVG WEIGHT TODAY" android:textSize="8sp" android:textColor="#FF5252" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView
                            android:id="@+id/tv_est_weight_gain"
                            android:text="0.0 KG"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#FF5252"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                        <TextView
                            android:text="LIVE MONITORING"
                            android:textColor="#FFCDD2"
                            android:textSize="8sp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </HorizontalScrollView>

        <!-- Growth Intelligence Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/growth_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:layout_constraintTop_toBottomOf="@id/stats_scroll">
            <LinearLayout
                android:padding="16dp"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <View
                        android:layout_width="20dp"
                        android:layout_height="4dp"
                        android:background="#4CAF50"
                        android:layout_marginEnd="8dp"/>
                    <TextView android:text="PERFORMANCE ANALYTICS" android:textSize="10sp" android:textColor="#4CAF50" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>

                <TextView android:text="Growth Intelligence" android:textStyle="bold" android:textSize="22sp" android:textColor="@color/db_text_primary" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp"/>
                <TextView android:text="Real-time weight projection and batch velocity across the current cycle." android:textSize="12sp" android:textColor="@color/db_text_secondary" android:layout_width="wrap_content" android:layout_height="wrap_content"/>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:layout_marginTop="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Y-Axis: Weight (kg)"
                        android:textSize="8sp"
                        android:textColor="@color/db_text_secondary"
                        android:rotation="-90"
                        android:layout_centerVertical="true"
                        android:layout_alignParentStart="true" />

                    <androidx.compose.ui.platform.ComposeView
                        android:id="@+id/chart_compose_view"
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:layout_marginStart="30dp"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="X-Axis: Timeline (Days / Months)"
                        android:textSize="8sp"
                        android:textColor="@color/db_text_secondary"
                        android:layout_alignParentBottom="true"
                        android:layout_centerHorizontal="true" />
                </RelativeLayout>

                <!-- Legend and Summary Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp"
                    android:gravity="center_vertical">

                    <!-- Left: Peak Performance Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.2"
                        android:layout_marginEnd="12dp"
                        app:cardBackgroundColor="#0D1B2A"
                        app:cardCornerRadius="16dp">
                        <RelativeLayout
                            android:padding="16dp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">
                            <TextView android:text="PEAK PERFORMANCE" android:textSize="8sp" android:textColor="#4CAF50" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_flash"
                                android:layout_alignParentEnd="true"
                                app:tint="@color/db_text_secondary"/>
                            <TextView
                                android:id="@+id/tv_peak_batch"
                                android:text="BATCH002"
                                android:textColor="@color/white"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:layout_marginTop="20dp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>
                            <TextView
                                android:id="@+id/tv_peak_weight"
                                android:text="24.0 kg"
                                android:textColor="@color/white"
                                android:textSize="24sp"
                                android:textStyle="bold"
                                android:layout_below="@id/tv_peak_batch"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="4dp"
                                android:background="#4CAF50"
                                android:layout_below="@id/tv_peak_weight"
                                android:layout_marginTop="8dp"/>
                        </RelativeLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Right: Gain and Tracked Stats -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <LinearLayout
                            android:padding="10dp"
                            android:background="@drawable/rounded_stat_bg"
                            android:orientation="vertical"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp">
                            <TextView android:text="AVERAGE SYSTEM GAIN" android:textSize="8sp" android:textColor="@color/db_text_secondary" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            <TextView
                                android:id="@+id/tv_avg_system_gain"
                                android:text="21.3 kg"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/db_text_primary"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>
                        </LinearLayout>

                        <LinearLayout
                            android:padding="10dp"
                            android:background="@drawable/rounded_stat_bg"
                            android:orientation="vertical"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">
                            <TextView android:text="BATCHES TRACKED" android:textSize="8sp" android:textColor="@color/db_text_secondary" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            <TextView
                                android:id="@+id/tv_batches_tracked"
                                android:text="2 Active"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/db_text_primary"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
